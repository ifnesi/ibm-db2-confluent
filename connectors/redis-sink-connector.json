{
  "name": "redis-iot-devices-sink",
  "config": {
    "connector.class": "com.redis.kafka.connect.RedisSinkConnector",
    "tasks.max": "1",
    "topics": "iot_devices_merged,iot_devices_avg",
    "redis.uri": "redis://redis:6379",
    "redis.command": "JSONSET",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",
    "predicates": "isMergedTopic,isAvgTopic",
    "predicates.isMergedTopic.type": "org.apache.kafka.connect.transforms.predicates.TopicNameMatches",
    "predicates.isMergedTopic.pattern": "iot_devices_merged",
    "predicates.isAvgTopic.type": "org.apache.kafka.connect.transforms.predicates.TopicNameMatches",
    "predicates.isAvgTopic.pattern": "iot_devices_avg",
    "transforms": "tsCreated,tsWindowStart,tsWindowEnd,routeMerged",
    "transforms.routeMerged.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.routeMerged.regex": "iot_devices_merged",
    "transforms.routeMerged.replacement": "iot_devices",
    "transforms.tsCreated.type": "org.apache.kafka.connect.transforms.TimestampConverter$Value",
    "transforms.tsCreated.field": "updatedAt",
    "transforms.tsCreated.target.type": "string",
    "transforms.tsCreated.format": "yyyy-MM-dd HH:mm:ss",
    "transforms.tsCreated.predicate": "isMergedTopic",
    "transforms.tsWindowStart.type": "org.apache.kafka.connect.transforms.TimestampConverter$Value",
    "transforms.tsWindowStart.field": "window_start",
    "transforms.tsWindowStart.target.type": "string",
    "transforms.tsWindowStart.format": "yyyy-MM-dd HH:mm:ss",
    "transforms.tsWindowStart.predicate": "isAvgTopic",
    "transforms.tsWindowEnd.type": "org.apache.kafka.connect.transforms.TimestampConverter$Value",
    "transforms.tsWindowEnd.field": "window_end",
    "transforms.tsWindowEnd.target.type": "string",
    "transforms.tsWindowEnd.format": "yyyy-MM-dd HH:mm:ss",
    "transforms.tsWindowEnd.predicate": "isAvgTopic"
  }
}

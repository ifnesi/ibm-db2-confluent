{
  "name": "db2-source-connector",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSourceConnector",
    "tasks.max": "1",
    "connection.url": "jdbc:db2://db2-luw:50000/testdb",
    "connection.user": "db2inst1",
    "connection.password": "db2inst1-pwd",
    "mode": "timestamp",
    "timestamp.column.name": "CREATED_TIMESTAMP",
    "table.whitelist": "DB2INST1.IOT_DEVICES,DB2INST1.IOT_DEVICES_MEASUREMENTS",
    "validate.non.null": "false",
    "topic.prefix": "DB2INST1.",
    "poll.interval.ms": "500",
    "batch.max.rows": "100",
    "table.poll.interval.ms": "2000",
    "timestamp.delay.interval.ms": "0",
    "db.timezone": "UTC",
    "numeric.mapping": "best_fit",
    "transforms": "renameFields,createKey,extractString,renameTopicMeasurements,renameTopicDevices",
    "transforms.renameFields.type": "org.apache.kafka.connect.transforms.ReplaceField$Value",
    "transforms.renameFields.renames": "DEVICE_IDENTIFIER:deviceID,VENDOR_NAME:vendor,SERIAL_NUMBER:serialNumber,TEMP:temperature,HMDT:humidity,PRESS:pressure,CREATED_TIMESTAMP:updatedAt",
    "transforms.createKey.type": "org.apache.kafka.connect.transforms.ValueToKey",
    "transforms.createKey.fields": "deviceID",
    "transforms.extractString.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
    "transforms.extractString.field": "deviceID",
    "transforms.renameTopicMeasurements.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.renameTopicMeasurements.regex": "DB2INST1\\.IOT_DEVICES_MEASUREMENTS",
    "transforms.renameTopicMeasurements.replacement": "iot_devices_measurements_db2",
    "transforms.renameTopicDevices.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.renameTopicDevices.regex": "DB2INST1\\.IOT_DEVICES$",
    "transforms.renameTopicDevices.replacement": "iot_devices_db2",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081"
  }
}
